  <!-- Close/Back Button -->
  <widget type="action_button" version="3.0.0">
    <name>CloseBtn</name>
    <x>1200</x>
    <y>915</y>
    <width>70</width>
    <height>35</height>
    <text>✕ Close</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="100" green="60" blue="60"/>
    </background_color>
    <actions>
      <action type="open_display">
        <file>CameraV2_Main.bob</file>
        <target>replace</target>
        <description>Back to Main</description>
      </action>
    </actions>
  </widget>

</display>
