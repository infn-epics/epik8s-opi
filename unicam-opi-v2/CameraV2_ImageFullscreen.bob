<?xml version="1.0" encoding="UTF-8"?>
<!--Camera V2 - Fullscreen Image Display-->
<display version="2.0.0">
  <name>Fullscreen Image</name>
  <width>1280</width>
  <height>960</height>
  <background_color>
    <color red="10" green="12" blue="18"/>
  </background_color>

  <!-- Background -->
  <widget type="rectangle" version="2.0.0">
    <name>Background</name>
    <x>0</x>
    <y>0</y>
    <width>1280</width>
    <height>960</height>
    <line_width>0</line_width>
    <background_color>
      <color red="10" green="12" blue="18"/>
    </background_color>
  </widget>

  <!-- Main Image -->
  <widget type="image" version="2.0.0">
    <name>FullscreenImage</name>
    <pv_name>pva://$(DEVICE):$(CAM):PVA:OUTPUT</pv_name>
    <x>40</x>
    <y>50</y>
    <width>1200</width>
    <height>850</height>
    <color_mode>1</color_mode>
    <background_color>
      <color red="10" green="12" blue="18"/>
    </background_color>
    <x_axis>
      <visible>false</visible>
    </x_axis>
    <y_axis>
      <visible>false</visible>
    </y_axis>
    <color_bar>
      <visible>false</visible>
    </color_bar>
    <autoscale>true</autoscale>
    <rules>
      <rule name="ImageSourceRule" prop_id="pv_name" out_exp="true">
        <exp bool_exp="pv0==0">
          <expression>"pva://$(DEVICE):$(CAM):PVA:OUTPUT"</expression>
        </exp>
        <exp bool_exp="pv0==1">
          <expression>"pva://$(DEVICE):$(CAM):ROI1:OUTPUT"</expression>
        </exp>
        <exp bool_exp="pv0==2">
          <expression>"pva://$(DEVICE):$(CAM):PROC:OUTPUT"</expression>
        </exp>
        <exp bool_exp="pv0==3">
          <expression>"pva://$(DEVICE):$(CAM):OVERLAY1:OUTPUT"</expression>
        </exp>
        <pv_name>loc://$(DEVICE):$(CAM):FullscreenSource&lt;VEnum&gt;(0, "Raw", "ROI", "Processed", "Overlay")</pv_name>
      </rule>
    </rules>
  </widget>

  <!-- Top Bar -->
  <widget type="rectangle" version="2.0.0">
    <name>TopBar</name>
    <x>0</x>
    <y>0</y>
    <width>1280</width>
    <height>45</height>
    <line_width>0</line_width>
    <background_color>
      <color red="20" green="24" blue="32"/>
    </background_color>
  </widget>

  <!-- Title -->
  <widget type="label" version="2.0.0">
    <name>TitleLabel</name>
    <text>$(DEVICE):$(CAM) - Fullscreen View</text>
    <x>15</x>
    <y>8</y>
    <width>400</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="16.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <!-- Source Selector -->
  <widget type="label" version="2.0.0">
    <name>SourceLabel</name>
    <text>Source:</text>
    <x>430</x>
    <y>8</y>
    <width>60</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="12.0"/>
    </font>
    <foreground_color>
      <color red="180" green="180" blue="180"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="combo" version="2.0.0">
    <name>SourceCombo</name>
    <pv_name>loc://$(DEVICE):$(CAM):FullscreenSource&lt;VEnum&gt;(0, "Raw", "ROI", "Processed", "Overlay")</pv_name>
    <x>495</x>
    <y>8</y>
    <width>120</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="50" green="60" blue="80"/>
    </background_color>
  </widget>

  <!-- Colormap Selector -->
  <widget type="label" version="2.0.0">
    <name>ColormapLabel</name>
    <text>Colormap:</text>
    <x>640</x>
    <y>8</y>
    <width>70</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="12.0"/>
    </font>
    <foreground_color>
      <color red="180" green="180" blue="180"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="combo" version="2.0.0">
    <name>ColormapCombo</name>
    <pv_name>loc://$(DEVICE):$(CAM):Colormap&lt;VEnum&gt;(0, "Gray", "Viridis", "Plasma", "Hot", "Cool")</pv_name>
    <x>715</x>
    <y>8</y>
    <width>100</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="50" green="60" blue="80"/>
    </background_color>
  </widget>

