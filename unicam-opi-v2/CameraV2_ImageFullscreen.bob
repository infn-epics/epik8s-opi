  <!-- Acquisition controls -->
  <widget type="action_button" version="3.0.0">
    <name>StartBtn</name>
    <pv_name>$(DEVICE):$(CAM):Acquire</pv_name>
    <x>920</x>
    <y>915</y>
    <width>80</width>
    <height>35</height>
    <text>▶ Start</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="140" blue="40"/>
    </background_color>
    <actions>
      <action type="write_pv">
        <pv_name>$(pv_name)</pv_name>
        <value>1</value>
        <description>Start Acquisition</description>
      </action>
    </actions>
  </widget>

  <widget type="action_button" version="3.0.0">
    <name>StopBtn</name>
    <pv_name>$(DEVICE):$(CAM):Acquire</pv_name>
    <x>1010</x>
    <y>915</y>
    <width>80</width>
    <height>35</height>
    <text>⏹ Stop</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="180" green="50" blue="50"/>
    </background_color>
    <actions>
      <action type="write_pv">
        <pv_name>$(pv_name)</pv_name>
        <value>0</value>
        <description>Stop Acquisition</description>
      </action>
    </actions>
  </widget>

  <!-- Capture Button -->
  <widget type="action_button" version="3.0.0">
    <name>CaptureBtn</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:Capture</pv_name>
    <x>1100</x>
    <y>915</y>
    <width>90</width>
