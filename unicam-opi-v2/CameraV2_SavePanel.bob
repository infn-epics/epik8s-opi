      <color red="255" green="200" blue="100"/>
    </foreground_color>
    <transparent>true</transparent>
  </widget>

  <widget type="rectangle" version="2.0.0">
    <name>WriteModeSectionBg</name>
    <x>5</x>
    <y>305</y>
    <width>330</width>
    <height>90</height>
    <line_width>1</line_width>
    <line_color>
      <color red="70" green="80" blue="100"/>
    </line_color>
    <background_color>
      <color red="35" green="42" blue="55"/>
    </background_color>
    <corner_width>8</corner_width>
    <corner_height>8</corner_height>
  </widget>

  <widget type="combo" version="2.0.0">
    <name>WriteModeCombo</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:FileWriteMode</pv_name>
    <x>15</x>
    <y>320</y>
    <width>150</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="11.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="50" green="60" blue="80"/>
    </background_color>
  </widget>

  <!-- Number to Capture (for Stream/Capture modes) -->
  <widget type="label" version="2.0.0">
    <name>NumCaptureLabel</name>
    <text>Num to Capture:</text>
    <x>175</x>
    <y>320</y>
    <width>95</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="11.0"/>
    </font>
    <foreground_color>
      <color red="180" green="180" blue="180"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="textentry" version="3.0.0">
    <name>NumCaptureInput</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:NumCapture</pv_name>
    <x>270</x>
    <y>320</y>
    <width>55</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="50" green="60" blue="80"/>
    </background_color>
    <format>1</format>
    <horizontal_alignment>1</horizontal_alignment>
  </widget>

  <!-- Captured count -->
  <widget type="label" version="2.0.0">
    <name>CapturedLabel</name>
    <text>Captured:</text>
    <x>15</x>
    <y>360</y>
    <width>70</width>
    <height>26</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="11.0"/>
    </font>
    <foreground_color>
      <color red="180" green="180" blue="180"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>NumCapturedRBV</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:NumCaptured_RBV</pv_name>
    <x>90</x>
    <y>360</y>
    <width>75</width>
    <height>26</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="14.0"/>
    </font>
    <foreground_color>
      <color red="100" green="255" blue="150"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>1</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <!-- File # -->
  <widget type="label" version="2.0.0">
    <name>FileNumLabel</name>
