    <x>175</x>
    <y>360</y>
    <width>50</width>
    <height>26</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="11.0"/>
    </font>
    <foreground_color>
      <color red="180" green="180" blue="180"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="textentry" version="3.0.0">
    <name>FileNumberInput</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:FileNumber</pv_name>
    <x>230</x>
    <y>360</y>
    <width>95</width>
    <height>26</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="50" green="60" blue="80"/>
    </background_color>
    <format>1</format>
    <horizontal_alignment>1</horizontal_alignment>
  </widget>

  <!-- Actions Section -->
  <widget type="label" version="2.0.0">
    <name>ActionsHeader</name>
    <text>⚡ Actions</text>
    <x>5</x>
    <y>405</y>
    <width>330</width>
    <height>26</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="13.0"/>
    </font>
    <foreground_color>
      <color red="150" green="255" blue="150"/>
    </foreground_color>
    <transparent>true</transparent>
  </widget>

  <widget type="rectangle" version="2.0.0">
    <name>ActionsSectionBg</name>
    <x>5</x>
    <y>435</y>
    <width>330</width>
    <height>80</height>
    <line_width>1</line_width>
    <line_color>
      <color red="70" green="80" blue="100"/>
    </line_color>
    <background_color>
      <color red="35" green="42" blue="55"/>
    </background_color>
    <corner_width>8</corner_width>
    <corner_height>8</corner_height>
  </widget>

  <!-- Capture / Write buttons -->
  <widget type="action_button" version="3.0.0">
    <name>CaptureBtn</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:Capture</pv_name>
    <x>15</x>
    <y>450</y>
    <width>95</width>
    <height>50</height>
    <text>📸 Capture</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="12.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="80" green="160" blue="80"/>
    </background_color>
    <actions>
      <action type="write_pv">
        <pv_name>$(pv_name)</pv_name>
        <value>1</value>
        <description>Start Capture</description>
      </action>
    </actions>
  </widget>

  <widget type="action_button" version="3.0.0">
    <name>WriteFileBtn</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:WriteFile</pv_name>
    <x>120</x>
    <y>450</y>
    <width>95</width>
    <height>50</height>
    <text>✏️ Write File</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="60" green="120" blue="180"/>
    </background_color>
    <actions>
      <action type="write_pv">
        <pv_name>$(pv_name)</pv_name>
        <value>1</value>
        <description>Write File</description>
      </action>
    </actions>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>WriteStatusRBV</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:WriteStatus</pv_name>
    <x>225</x>
    <y>450</y>
    <width>100</width>
    <height>20</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
    <rules>
      <rule name="WriteStatusColor" prop_id="foreground_color" out_exp="false">
        <exp bool_exp="pv0==0">
          <value>
            <color red="100" green="255" blue="150"/>
          </value>
        </exp>
        <exp bool_exp="pv0==1">
          <value>
            <color red="255" green="100" blue="100"/>
          </value>
        </exp>
        <pv_name>$(DEVICE):$(CAM):TIFF1:WriteStatus</pv_name>
      </rule>
    </rules>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>WriteMessageRBV</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:WriteMessage</pv_name>
    <x>225</x>
    <y>475</y>
    <width>100</width>
    <height>20</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="9.0"/>
    </font>
    <foreground_color>
      <color red="200" green="200" blue="200"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>

