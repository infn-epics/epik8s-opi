  <widget type="textupdate" version="2.0.0">
    <name>FullFileNameRBV</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:FullFileName_RBV</pv_name>
    <x>15</x>
    <y>565</y>
    <width>310</width>
    <height>20</height>
    <font>
      <font family="Liberation Mono" style="REGULAR" size="10.0"/>
    </font>
    <foreground_color>
      <color red="150" green="200" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>6</format>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="label" version="2.0.0">
    <name>PathExistsLabel</name>
    <text>Path:</text>
    <x>15</x>
    <y>590</y>
    <width>40</width>
    <height>18</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="10.0"/>
    </font>
    <foreground_color>
      <color red="150" green="150" blue="150"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>FilePathExistsRBV</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:FilePathExists_RBV</pv_name>
    <x>55</x>
    <y>590</y>
    <width>60</width>
    <height>18</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
    <rules>
      <rule name="PathExistsColor" prop_id="foreground_color" out_exp="false">
        <exp bool_exp="pv0==0">
          <value>
            <color red="255" green="100" blue="100"/>
          </value>
        </exp>
        <exp bool_exp="pv0!=0">
          <value>
            <color red="100" green="255" blue="150"/>
          </value>
        </exp>
        <pv_name>$(DEVICE):$(CAM):TIFF1:FilePathExists_RBV</pv_name>
      </rule>
    </rules>
  </widget>

  <widget type="bool_button" version="2.0.0">
    <name>AutoSaveBtn</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:AutoSave</pv_name>
    <x>125</x>
    <y>586</y>
    <width>90</width>
    <height>22</height>
    <off_label>No Auto</off_label>
