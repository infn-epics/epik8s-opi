    </on_color>
    <font>
      <font family="Liberation Sans" style="BOLD" size="9.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
  </widget>

  <widget type="action_button" version="3.0.0">
    <name>CreateDirBtn</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:CreateDirectory</pv_name>
    <x>225</x>
    <y>586</y>
