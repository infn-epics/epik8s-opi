    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="200" green="100" blue="60"/>
    </background_color>
    <actions>
      <action type="write_pv">
        <pv_name>$(DEVICE):$(CAM):Over1:1:Use</pv_name>
        <value>1</value>
        <description>Enable</description>
      </action>
      <action type="write_pv">
        <pv_name>$(DEVICE):$(CAM):Over1:1:Shape</pv_name>
        <value>0</value>
        <description>Cross</description>
      </action>
      <action type="write_pv">
        <pv_name>$(DEVICE):$(CAM):Over1:1:CenterXLink</pv_name>
        <value>$(DEVICE):$(CAM):Stats1:CentroidX_RBV</value>
        <description>Link X</description>
