  <!-- Preset buttons -->
  <widget type="action_button" version="3.0.0">
    <name>PresetCentroidBtn</name>
    <x>15</x>
    <y>495</y>
    <width>145</width>
    <height>35</height>
    <text>🎯 Centroid Crosshair</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
