  <widget type="action_button" version="3.0.0">
    <name>SaveFlatBtn</name>
    <pv_name>$(DEVICE):$(CAM):Proc1:SaveFlatField</pv_name>
    <x>125</x>
    <y>285</y>
    <width>90</width>
    <height>32</height>
    <text>Save Flat</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="60" green="80" blue="130"/>
    </background_color>
    <actions>
      <action type="write_pv">
        <pv_name>$(pv_name)</pv_name>
        <value>1</value>
        <description>Save Flat Field</description>
      </action>
    </actions>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>FlatValidRBV</name>
    <pv_name>$(DEVICE):$(CAM):Proc1:ValidFlatField_RBV</pv_name>
    <x>225</x>
    <y>285</y>
    <width>100</width>
    <height>32</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
    <rules>
      <rule name="FlatValidColor" prop_id="background_color" out_exp="false">
        <exp bool_exp="pv0==0">
          <value>
            <color red="100" green="60" blue="60"/>
          </value>
        </exp>
        <exp bool_exp="pv0!=0">
          <value>
            <color red="60" green="120" blue="60"/>
          </value>
        </exp>
        <pv_name>$(DEVICE):$(CAM):Proc1:ValidFlatField_RBV</pv_name>
      </rule>
    </rules>
  </widget>

