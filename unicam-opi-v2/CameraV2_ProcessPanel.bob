  <widget type="bool_button" version="2.0.0">
    <name>EnableFlatFieldBtn</name>
    <pv_name>$(DEVICE):$(CAM):Proc1:EnableFlatField</pv_name>
    <x>15</x>
    <y>285</y>
    <width>100</width>
    <height>32</height>
    <off_label>Disabled</off_label>
    <off_color>
      <color red="80" green="80" blue="80"/>
    </off_color>
    <on_label>Enabled</on_label>
    <on_color>
      <color red="200" green="140" blue="40"/>
    </on_color>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
