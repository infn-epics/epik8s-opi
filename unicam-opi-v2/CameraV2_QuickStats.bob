<?xml version="1.0" encoding="UTF-8"?>
<!--Camera V2 - Quick Stats Panel (Right Side)-->
<display version="2.0.0">
  <name>Quick Stats</name>
  <width>290</width>
  <height>690</height>
  <background_color>
    <color red="40" green="46" blue="58" alpha="0"/>
  </background_color>

  <!-- Live Statistics Section -->
  <widget type="label" version="2.0.0">
    <name>StatsHeader</name>
    <text>📊 Live Statistics</text>
    <x>5</x>
    <y>5</y>
    <width>280</width>
    <height>28</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="14.0"/>
    </font>
    <foreground_color>
      <color red="255" green="180" blue="50"/>
    </foreground_color>
    <transparent>true</transparent>
  </widget>

  <widget type="rectangle" version="2.0.0">
    <name>StatsSectionBg</name>
    <x>5</x>
    <y>37</y>
    <width>280</width>
    <height>200</height>
    <line_width>1</line_width>
    <line_color>
      <color red="70" green="80" blue="100"/>
    </line_color>
    <background_color>
      <color red="35" green="42" blue="55"/>
    </background_color>
    <corner_width>8</corner_width>
    <corner_height>8</corner_height>
  </widget>

  <!-- Min Value -->
  <widget type="label" version="2.0.0">
    <name>MinLabel</name>
    <text>Min:</text>
    <x>15</x>
    <y>50</y>
    <width>60</width>
    <height>24</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="12.0"/>
    </font>
    <foreground_color>
      <color red="180" green="180" blue="180"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>MinValueRBV</name>
    <pv_name>$(DEVICE):$(CAM):Stats1:MinValue_RBV</pv_name>
    <x>80</x>
    <y>50</y>
    <width>100</width>
    <height>24</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="14.0"/>
    </font>
    <foreground_color>
      <color red="100" green="200" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>0</format>
    <horizontal_alignment>2</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <!-- Max Value -->
  <widget type="label" version="2.0.0">
    <name>MaxLabel</name>
    <text>Max:</text>
    <x>15</x>
    <y>80</y>
