  <!-- Write Status -->
  <widget type="textupdate" version="2.0.0">
    <name>WriteStatusRBV</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:WriteStatus</pv_name>
    <x>160</x>
    <y>510</y>
    <width>115</width>
    <height>24</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="40" green="50" blue="65"/>
    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
    <rules>
      <rule name="WriteStatusColor" prop_id="foreground_color" out_exp="false">
        <exp bool_exp="pv0==0">
          <value>
            <color red="100" green="255" blue="150"/>
          </value>
        </exp>
        <exp bool_exp="pv0==1">
          <value>
            <color red="255" green="100" blue="100"/>
          </value>
        </exp>
        <pv_name>$(DEVICE):$(CAM):TIFF1:WriteStatus</pv_name>
      </rule>
    </rules>
  </widget>

  <!-- Current File Name -->
  <widget type="label" version="2.0.0">
