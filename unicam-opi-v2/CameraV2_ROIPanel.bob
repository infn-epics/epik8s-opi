  <widget type="action_button" version="3.0.0">
    <name>FullFrameBtn</name>
    <x>145</x>
    <y>340</y>
    <width>80</width>
    <height>26</height>
    <text>Full</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="70" green="100" blue="140"/>
    </background_color>
    <tooltip>Set ROI to full frame</tooltip>
    <actions>
      <action type="execute">
        <description>Set Full Frame ROI</description>
        <script file="EmbeddedPy">
          <text><![CDATA[
# Set ROI to full sensor size
from org.csstudio.display.builder.runtime.script import PVUtil

pv_minx = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:MinX", 1000)
pv_miny = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:MinY", 1000)
pv_sizex = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:SizeX", 1000)
pv_sizey = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:SizeY", 1000)
pv_maxsizex = PVUtil.createPV("$(DEVICE):$(CAM):MaxSizeX_RBV", 1000)
pv_maxsizey = PVUtil.createPV("$(DEVICE):$(CAM):MaxSizeY_RBV", 1000)

maxX = PVUtil.getInt(pv_maxsizex)
maxY = PVUtil.getInt(pv_maxsizey)

pv_minx.setValue(0)
pv_miny.setValue(0)
pv_sizex.setValue(maxX)
pv_sizey.setValue(maxY)
          ]]></text>
        </script>
      </action>
    </actions>
  </widget>

  <widget type="action_button" version="3.0.0">
    <name>CenterBtn</name>
    <x>230</x>
    <y>340</y>
    <width>80</width>
    <height>26</height>
    <text>Center</text>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="70" green="100" blue="140"/>
    </background_color>
    <tooltip>Center ROI in frame</tooltip>
    <actions>
      <action type="execute">
        <description>Center ROI</description>
        <script file="EmbeddedPy">
          <text><![CDATA[
# Center ROI in frame
from org.csstudio.display.builder.runtime.script import PVUtil

pv_minx = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:MinX", 1000)
pv_miny = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:MinY", 1000)
pv_sizex = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:SizeX_RBV", 1000)
pv_sizey = PVUtil.createPV("$(DEVICE):$(CAM):Roi1:SizeY_RBV", 1000)
pv_maxsizex = PVUtil.createPV("$(DEVICE):$(CAM):MaxSizeX_RBV", 1000)
pv_maxsizey = PVUtil.createPV("$(DEVICE):$(CAM):MaxSizeY_RBV", 1000)

maxX = PVUtil.getInt(pv_maxsizex)
maxY = PVUtil.getInt(pv_maxsizey)
sizeX = PVUtil.getInt(pv_sizex)
sizeY = PVUtil.getInt(pv_sizey)

newMinX = (maxX - sizeX) // 2
newMinY = (maxY - sizeY) // 2

pv_minx.setValue(newMinX)
pv_miny.setValue(newMinY)
          ]]></text>
        </script>
      </action>
    </actions>
  </widget>

