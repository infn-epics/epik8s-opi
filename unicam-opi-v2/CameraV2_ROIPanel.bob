<?xml version="1.0" encoding="UTF-8"?>
<!--Camera V2 - ROI Panel-->
<display version="2.0.0">
  <name>ROI Panel</name>
  <width>340</width>
  <height>800</height>
  <background_color>
    <color red="50" green="58" blue="72" alpha="0"/>
  </background_color>

  <!-- ROI Enable Section -->
  <widget type="label" version="2.0.0">
    <name>ROIHeader</name>
    <text>🔲 Region of Interest (ROI)</text>
    <x>10</x>
    <y>10</y>
    <width>320</width>
    <height>28</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="14.0"/>
    </font>
    <foreground_color>
      <color red="0" green="180" blue="255"/>
    </foreground_color>
    <transparent>true</transparent>
  </widget>

  <widget type="rectangle" version="2.0.0">
    <name>ROISectionBg</name>
    <x>10</x>
    <y>42</y>
    <width>320</width>
    <height>350</height>
    <line_width>1</line_width>
    <line_color>
      <color red="70" green="80" blue="100"/>
    </line_color>
    <background_color>
      <color red="35" green="42" blue="55"/>
    </background_color>
    <corner_width>8</corner_width>
    <corner_height>8</corner_height>
  </widget>

  <!-- Enable ROI -->
  <widget type="label" version="2.0.0">
    <name>ROIEnableLabel</name>
    <text>Enable ROI Processing:</text>
    <x>20</x>
    <y>55</y>
    <width>180</width>
    <height>30</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="12.0"/>
    </font>
    <foreground_color>
      <color red="200" green="200" blue="200"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="bool_button" version="2.0.0">
    <name>ROIEnableBtn</name>
    <pv_name>$(DEVICE):$(CAM):Roi1:EnableCallbacks</pv_name>
    <x>200</x>
    <y>55</y>
    <width>120</width>
    <height>30</height>
    <off_label>DISABLED</off_label>
    <off_color>
      <color red="80" green="80" blue="80"/>
    </off_color>
    <on_label>ENABLED</on_label>
    <on_color>
      <color red="0" green="180" blue="100"/>
    </on_color>
    <font>
      <font family="Liberation Sans" style="BOLD" size="10.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
  </widget>

  <!-- Input Source -->
  <widget type="label" version="2.0.0">
    <name>InputLabel</name>
    <text>Input Source:</text>
    <x>20</x>
    <y>95</y>
    <width>100</width>
