<?xml version="1.0" encoding="UTF-8"?>
<!--Camera V2 - Bottom Status Bar-->
<display version="2.0.0">
  <name>Bottom Status</name>
  <width>1590</width>
  <height>36</height>
  <background_color>
    <color red="25" green="30" blue="38"/>
  </background_color>

  <!-- Status Background -->
  <widget type="rectangle" version="2.0.0">
    <name>StatusBarBg</name>
    <x>0</x>
    <y>0</y>
    <width>1590</width>
    <height>36</height>
    <line_width>0</line_width>
    <background_color>
      <color red="25" green="30" blue="38"/>
    </background_color>
  </widget>

  <!-- Top border line -->
  <widget type="rectangle" version="2.0.0">
    <name>TopBorder</name>
    <x>0</x>
    <y>0</y>
    <width>1590</width>
    <height>1</height>
    <line_width>0</line_width>
    <background_color>
      <color red="60" green="70" blue="90"/>
    </background_color>
  </widget>

  <!-- Camera Status -->
  <widget type="label" version="2.0.0">
    <name>CamStatusLabel</name>
    <text>Camera:</text>
    <x>10</x>
    <y>7</y>
    <width>55</width>
    <height>22</height>
    <font>
      <font family="Liberation Sans" style="REGULAR" size="11.0"/>
    </font>
    <foreground_color>
      <color red="150" green="150" blue="150"/>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="textupdate" version="2.0.0">
    <name>CameraStatusRBV</name>
    <pv_name>$(DEVICE):$(CAM):DetectorState_RBV</pv_name>
    <x>65</x>
    <y>7</y>
    <width>80</width>
    <height>22</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0"/>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255"/>
    </foreground_color>
    <background_color>
      <color red="35" green="42" blue="55"/>
    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
    <rules>
      <rule name="DetectorStateColor" prop_id="background_color" out_exp="false">
        <exp bool_exp="pv0==0">
          <value>
            <color red="60" green="60" blue="60"/>
          </value>
        </exp>
        <exp bool_exp="pv0==1">
          <value>
            <color red="40" green="120" blue="40"/>
          </value>
        </exp>
        <exp bool_exp="pv0==2">
          <value>
            <color red="180" green="180" blue="40"/>
          </value>
        </exp>
        <exp bool_exp="pv0==3">
          <value>
            <color red="180" green="100" blue="40"/>
          </value>
        </exp>
        <exp bool_exp="pv0>=4">
          <value>
            <color red="180" green="40" blue="40"/>
          </value>
        </exp>
        <pv_name>$(DEVICE):$(CAM):DetectorState_RBV</pv_name>
      </rule>
    </rules>
  </widget>

  <!-- Separator -->
  <widget type="rectangle" version="2.0.0">
    <name>Sep1</name>
    <x>155</x>
    <y>5</y>
    <width>1</width>
    <height>26</height>
    <line_width>0</line_width>
    <background_color>
      <color red="60" green="70" blue="90"/>
    </background_color>
  </widget>

