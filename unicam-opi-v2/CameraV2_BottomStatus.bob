  <!-- TIFF Status LED -->
  <widget type="led" version="2.0.0">
    <name>TIFFLED</name>
    <pv_name>$(DEVICE):$(CAM):TIFF1:EnableCallbacks_RBV</pv_name>
    <x>1528</x>
    <y>9</y>
    <width>16</width>
    <height>16</height>
    <off_color>
      <color red="60" green="60" blue="60"/>
    </off_color>
    <on_color>
      <color red="100" green="200" blue="100"/>
    </on_color>
    <tooltip>TIFF Writer</tooltip>
  </widget>

  <!-- Stream Status LED -->
  <widget type="led" version="2.0.0">
    <name>StreamLED</name>
    <pv_name>$(DEVICE):$(CAM):Pva1:EnableCallbacks_RBV</pv_name>
    <x>1550</x>
    <y>9</y>
    <width>16</width>
    <height>16</height>
    <off_color>
      <color red="60" green="60" blue="60"/>
    </off_color>
    <on_color>
      <color red="255" green="100" blue="150"/>
    </on_color>
    <tooltip>PVA Stream</tooltip>
  </widget>

  <!-- Time indicator (right corner) -->
  <widget type="textupdate" version="2.0.0">
    <name>TimeStamp</name>
    <pv_name>$(DEVICE):$(CAM):TimeStamp_RBV</pv_name>
    <x>1575</x>
    <y>7</y>
    <width>0</width>
    <height>0</height>
    <visible>false</visible>
  </widget>

</display>
