    </background_color>
    <format>6</format>
    <horizontal_alignment>1</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
    <rules>
      <rule name="TIFFColor" prop_id="foreground_color" out_exp="false">
        <exp bool_exp="pv0==0">
          <value>
            <color red="180" green="180" blue="180"/>
          </value>
        </exp>
        <exp bool_exp="pv0==1">
          <value>
            <color red="100" green="255" blue="150"/>
          </value>
        </exp>
        <pv_name>$(DEVICE):$(CAM):TIFF1:Capture_RBV</pv_name>
      </rule>
    </rules>
  </widget>

